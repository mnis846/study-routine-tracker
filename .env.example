# Database — SQLite for local dev, PostgreSQL for production multi-user
DATABASE_URL=sqlite:///reflex_study_tracker.db
# DATABASE_URL=postgresql://user:password@localhost:5432/study_tracker

# Auth
AUTH_SECRET=change-me-in-production

# Bootstrap admin (created on first run)
ADMIN_BOOTSTRAP_EMAIL=admin@studytracker.local
ADMIN_BOOTSTRAP_PASSWORD=admin123

# Optional: Supabase Auth (wire in auth_service when ready)
SUPABASE_URL=
SUPABASE_ANON_KEY=